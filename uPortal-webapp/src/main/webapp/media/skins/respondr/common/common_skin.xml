<resources xmlns="http://www.jasig.org/uportal/web/skin"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://www.jasig.org/uportal/web/skin https://source.jasig.org/schemas/resource-server/skin-configuration/skin-configuration-v1.2.xsd">

    <!-- modernizr removed 2026-05-06: zero Modernizr.* callsites in workspace,
         no .no-js/.js class dependencies. Pure dead weight. -->

    <!--
    | NOTE:  The following order is important!
    +-->
    <js included="plain">/resource-server/webjars/jquery/dist/jquery.js</js>
    <js included="aggregated">/resource-server/webjars/jquery/dist/jquery.min.js</js>


    <!-- Bootstrap 5 CSS -->
    <css included="plain">/resource-server/webjars/bootstrap/dist/css/bootstrap.css</css>
    <css included="aggregated">/resource-server/webjars/bootstrap/dist/css/bootstrap.min.css</css>

    <!-- Bootstrap 5 JS -->
    <js included="plain">/resource-server/webjars/bootstrap/dist/js/bootstrap.bundle.js</js>
    <js included="aggregated">/resource-server/webjars/bootstrap/dist/js/bootstrap.bundle.min.js</js>

    <js included="plain">/resource-server/webjars/jquery-migrate/dist/jquery-migrate.js</js>
    <js included="aggregated">/resource-server/webjars/jquery-migrate/dist/jquery-migrate.min.js</js>

    <js included="plain">/resource-server/webjars/jquery-ui/dist/jquery-ui.js</js>
    <js included="aggregated">/resource-server/webjars/jquery-ui/dist/jquery-ui.min.js</js>

    <!-- Uncomment for internationalization.  Removed for minor efficiency especially for mobile networks. -->
    <!--
    <js included="plain" resource="true">/ResourceServingWebapp/rs/jqueryui/1.10.3/i18n/jquery-ui-i18n.js</js>
    <js included="aggregated" resource="true">/ResourceServingWebapp/rs/jqueryui/1.10.3/i18n/jquery-ui-i18n.min.js</js>
    -->




    <js included="plain">/resource-server/rs/underscore/1.8.3/underscore.js</js>
    <js included="aggregated">/resource-server/rs/underscore/1.8.3/underscore.min.js</js>

    <js included="plain">/resource-server/rs/backbone/1.3.3/backbone-1.3.3.js</js>
    <js included="aggregated">/resource-server/rs/backbone/1.3.3/backbone-1.3.3.min.js</js>

    <js included="plain">/resource-server/rs/jquery-plugins/noty/2.4.1/jquery.noty.packaged.js</js>
    <js included="aggregated">/resource-server/rs/jquery-plugins/noty/2.4.1/jquery.noty.packaged.min.js</js>

    <!-- DataTables 2.3.7 Core -->
    <js included="plain">/resource-server/webjars/datatables.net/js/dataTables.js</js>
    <js included="aggregated">/resource-server/webjars/datatables.net/js/dataTables.min.js</js>

    <!-- DataTables Bootstrap 5 Integration -->
    <js included="plain">/resource-server/webjars/datatables.net-bs5/js/dataTables.bootstrap5.js</js>
    <js included="aggregated">/resource-server/webjars/datatables.net-bs5/js/dataTables.bootstrap5.min.js</js>
    <css included="plain">/resource-server/webjars/datatables.net-bs5/css/dataTables.bootstrap5.css</css>
    <css included="aggregated">/resource-server/webjars/datatables.net-bs5/css/dataTables.bootstrap5.min.css</css>

    <!-- Rating Includes -->
    <js included="plain">/resource-server/rs/jquery-plugins/rating/1.0/bootstrap-rating-input.js</js>
    <js included="aggregated">/resource-server/rs/jquery-plugins/rating/1.0/bootstrap-rating-input.min.js</js>

    <!-- DataTables SearchPanes for column filtering (modern replacement for ColumnFilterWidgets) -->
    <js included="plain">/resource-server/webjars/datatables.net-searchpanes/js/dataTables.searchPanes.js</js>
    <js included="aggregated">/resource-server/webjars/datatables.net-searchpanes/js/dataTables.searchPanes.min.js</js>
    <js included="plain">/resource-server/webjars/datatables.net-searchpanes-bs5/js/searchPanes.bootstrap5.js</js>
    <js included="aggregated">/resource-server/webjars/datatables.net-searchpanes-bs5/js/searchPanes.bootstrap5.min.js</js>
    <css included="plain">/resource-server/webjars/datatables.net-searchpanes-bs5/css/searchPanes.bootstrap5.css</css>
    <css included="aggregated">/resource-server/webjars/datatables.net-searchpanes-bs5/css/searchPanes.bootstrap5.min.css</css>

    <!-- DataTables Select (required for SearchPanes) -->
    <js included="plain">/resource-server/webjars/datatables.net-select/js/dataTables.select.js</js>
    <js included="aggregated">/resource-server/webjars/datatables.net-select/js/dataTables.select.min.js</js>
    <js included="plain">/resource-server/webjars/datatables.net-select-bs5/js/select.bootstrap5.js</js>
    <js included="aggregated">/resource-server/webjars/datatables.net-select-bs5/js/select.bootstrap5.min.js</js>
    <css included="plain">/resource-server/webjars/datatables.net-select-bs5/css/select.bootstrap5.css</css>
    <css included="aggregated">/resource-server/webjars/datatables.net-select-bs5/css/select.bootstrap5.min.css</css>

    <!-- jsTree Includes (entity-selector) -->
    <js included="plain" resource="true">/webjars/jstree/dist/jstree.js</js>
    <js included="aggregated" resource="true">/webjars/jstree/dist/jstree.min.js</js>
    <css included="plain" resource="true">/webjars/jstree/dist/themes/default/style.css</css>
    <css included="aggregated" resource="true">/webjars/jstree/dist/themes/default/style.min.css</css>

    <!-- ES6+/fetch/async-await/Web-Components polyfills removed 2026-05-06.
         uPortal targets Bootstrap 5 baseline browsers (no IE), all of
         which natively support these APIs. Polyfills were dead weight. -->



    <js included="aggregated" resource="true">/scripts/portal-analytics.js</js>

    <js import="true">../../common/common_skin.xml</js>

</resources>
