{
  "extends": [
    "config:recommended",
    ":preserveSemverRanges",
    ":dependencyDashboard"
  ],
  "gradle": {
    "enabled": true
  },
  "major": {
    "dependencyDashboardApproval": true
  },
  "forkProcessing": "enabled",
  "packageRules": [
    {
      "matchPackageNames": [
        "/^org.springframework:/",
        "/^org.springframework.data:/",
        "/^org.springframework.webflow:/"
      ],
      "allowedVersions": "< 5.0",
      "description": "Pinned to Spring Framework 4.3.x. Spring 5+ is a coordinated migration (API changes); Spring 6+ additionally needs Jakarta EE + Java 17."
    },
    {
      "matchPackageNames": [
        "/^org.springframework.security:/",
        "/^org.springframework.security.oauth:/"
      ],
      "allowedVersions": "< 5.0",
      "description": "Pinned to Spring Security 4.2.x. Bound to the Spring Framework 4.3.x line; bumps in lockstep with a Spring core migration."
    },
    {
      "matchPackageNames": [
        "/^org.hibernate:/",
        "/^org.hibernate.orm:/"
      ],
      "allowedVersions": "< 5.0",
      "description": "Pinned to Hibernate 4.2.x. Hibernate 5+ requires a coordinated migration (API + EntityManager changes); Hibernate 6+ (groupId rename to org.hibernate.orm) needs Jakarta EE and Java 17+."
    },
    {
      "groupName": "uPortal",
      "matchPackageNames": ["/^org.jasig.portal:/"]
    },
    {
      "groupName": "uPortal web components",
      "matchPackageNames": ["/^org.webjars.npm:uportal/"]
    },
    {
      "groupName": "Person Directory",
      "matchPackageNames": ["/^org.apereo.service.persondir/"]
    },
    {
      "groupName": "Lucene",
      "matchPackageNames": ["/^org.apache.lucene/"]
    },
    {
      "groupName": "Mockito",
      "matchPackageNames": ["/^org.mockito/"]
    },
    {
      "groupName": "User Type",
      "matchPackageNames": ["/^org.jadira.usertype:usertype.core/"]
    },
    {
      "groupName": "JAXB2",
      "matchPackageNames": ["/^org.jvnet.jaxb2_commons/"]
    },
    {
      "groupName": "Resource Server",
      "matchPackageNames": ["/^org.jasig.resourceserver/"]
    },
    {
      "groupName": "Notification Portlet",
      "matchPackageNames": ["/^org.jasig.portlet.notification/"]
    },
    {
      "groupName": "AspectJ",
      "matchPackageNames": ["/^org.aspectj/"]
    },
    {
      "schedule": "on Monday",
      "matchPackageNames": ["/^com.amazonaws/"]
    },
    {
      "groupName": "SLF4J",
      "matchPackageNames": ["/^org.slf4j/"]
    },
    {
      "groupName": "Groovy",
      "matchPackageNames": ["/^org.codehaus.groovy/"]
    },
    {
      "groupName": "JSON Web Token",
      "matchPackageNames": ["/^io.jsonwebtoken/"]
    },
    {
      "groupName": "Apache Pluto",
      "matchPackageNames": ["/^org.apache.portals.pluto/"]
    },
    {
      "groupName": "JAXB",
      "matchPackageNames": ["/^com.sun.xml.bind/"]
    },
    {
      "groupName": "Jadira Usertype",
      "matchPackageNames": ["/^org.jadira.usertype/"]
    }
  ]
}
